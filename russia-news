            color: var(--text-gray);
            font-size: 0.85rem;
            margin-bottom: 2rem;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #eee;
            padding-bottom: 1rem;
        }
        .article-content {
            background: var(--card-bg);
            padding: 2rem;
            border-radius: 10px;
